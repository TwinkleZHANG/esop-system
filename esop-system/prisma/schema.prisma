generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// 激励计划
model Plan {
  id                     String       @id @default(cuid())
  title                  String
  type                   PlanType
  applicableJurisdiction Jurisdiction
  settlementMethod       String[]
  poolSize               Decimal      @db.Decimal(20, 4)
  effectiveDate          DateTime
  boardApprovalId        String?
  status                 PlanStatus   @default(PENDING_APPROVAL)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  grants                 Grant[]

  @@map("plans")
}

/// 员工档案
model Employee {
  id               String           @id @default(cuid())
  employeeId       String           @unique
  name             String
  department       String?
  legalIdentity    LegalIdentity
  employmentEntity String[]
  taxJurisdiction  Jurisdiction
  bankAccountType  BankAccountType?
  employmentStatus EmployeeStatus   @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  grants           Grant[]
  assetPositions   AssetPosition[]

  @@map("employees")
}

/// 用工主体
model EmploymentEntity {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("employment_entities")
}

/// 持股实体
model HoldingEntity {
  id             String       @id @default(cuid())
  heId           String       @unique
  name           String
  lpAccountId    String?
  lpUnits        Decimal?     @db.Decimal(20, 4)
  economicRights String[]
  type           String
  jurisdiction   Jurisdiction
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  assetPositions AssetPosition[]

  @@map("holding_entities")
}

/// 估值记录
model Valuation {
  id          String   @id @default(cuid())
  date        DateTime
  fmv         Decimal  @db.Decimal(20, 4)
  source      String?
  description String?
  createdAt   DateTime @default(now())

  @@map("valuations")
}

/// 授予记录
model Grant {
  id               String         @id @default(cuid())
  planId           String
  employeeId       String
  quantity         Decimal        @db.Decimal(20, 4)
  strikePrice      Decimal?       @db.Decimal(20, 4)
  grantDate        DateTime
  vestingStartDate DateTime
  vestingEndDate   DateTime?
  vestingYear      Int?
  cliffPeriod      Int?           @default(0)
  vestingFrequency String?
  status           GrantStatus    @default(DRAFT)
  type             PlanType
  processedQty     Decimal        @default(0) @db.Decimal(20, 4) // 已处理数量（行权/转让/赎回）
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  applications     Application[]
  employee         Employee       @relation(fields: [employeeId], references: [id])
  plan             Plan           @relation(fields: [planId], references: [id])
  taxEvents        TaxEvent[]
  vestingEvents    VestingEvent[]

  @@map("grants")
}

/// 归属事件
model VestingEvent {
  id            String        @id @default(cuid())
  grantId       String
  vestDate      DateTime
  quantity      Decimal       @db.Decimal(20, 4)
  cumulativeQty Decimal       @db.Decimal(20, 4)
  status        VestingStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  grant         Grant         @relation(fields: [grantId], references: [id])

  @@map("vesting_events")
}

/// 税务事件
model TaxEvent {
  id            String         @id @default(cuid())
  grantId       String
  eventType     TaxEventType
  triggerDate   DateTime
  quantity      Decimal        @db.Decimal(20, 4)
  taxableAmount Decimal?       @db.Decimal(20, 4)
  taxAmount     Decimal?       @db.Decimal(20, 4)
  status        TaxEventStatus @default(PENDING)
  receiptFileUrl String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  grant         Grant          @relation(fields: [grantId], references: [id])

  @@map("tax_events")
}

/// 员工申请（行权/转让/分红/赎回）
model Application {
  id           String            @id @default(cuid())
  grantId      String
  employeeId   String
  type         ApplicationType
  quantity     Decimal           @db.Decimal(20, 4)
  price        Decimal?          @db.Decimal(20, 4)
  status       ApplicationStatus @default(PENDING)
  remark       String?
  reviewerId   String?
  reviewRemark String?
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  grant        Grant             @relation(fields: [grantId], references: [id])

  @@map("applications")
}

/// 资产持仓
model AssetPosition {
  id              String        @id @default(cuid())
  accountId       String        @unique // Asset_Account_ID 展示用
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id])
  holdingEntityId String?
  holdingEntity   HoldingEntity? @relation(fields: [holdingEntityId], references: [id])

  assetType       AssetType
  quantity        Decimal       @db.Decimal(20, 4)  // 持有股数，固定不变
  currency        String        @default("CNY")
  status          AccountStatus @default(ACTIVE)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  transactions    AssetTransaction[]

  @@map("asset_positions")
}

/// 资产流水
model AssetTransaction {
  id              String        @id @default(cuid())
  trxId           String        @unique // TRX-日期-序号 展示用
  positionId      String
  position        AssetPosition @relation(fields: [positionId], references: [id])

  changeType      AssetTxType
  quantity        Decimal       @db.Decimal(20, 4) // 带符号，入账+，出账-
  costBasis       Decimal?      @db.Decimal(20, 4) // 交易时FMV单价
  balanceAfter    Decimal       @db.Decimal(20, 4) // 交易后余额快照
  tradeDate       DateTime

  relatedGrantId     String?
  relatedTaxEventId  String?

  createdAt       DateTime      @default(now())

  @@map("asset_transactions")
}

model AuditLog {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  action       String
  oldValue     Json?
  newValue     Json?
  operatorId   String?
  operatorRole String?
  createdAt    DateTime @default(now())

  @@map("audit_logs")
}

enum PlanType {
  RSU
  OPTION
  VIRTUAL_SHARE
  LP_SHARE
}

enum Jurisdiction {
  HK
  CN
  OVERSEAS
}

enum PlanStatus {
  PENDING_APPROVAL
  APPROVED
  CLOSED
}

enum LegalIdentity {
  CN_RESIDENT
  HK_RESIDENT
  OVERSEAS_RESIDENT
}

enum BankAccountType {
  DOMESTIC
  OVERSEAS
}

enum EmployeeStatus {
  ACTIVE
  TERMINATED
  ON_LEAVE
}

enum GrantStatus {
  DRAFT
  GRANTED
  VESTING
  VESTED
  EXERCISED
  SETTLED
  CANCELLED
  FORFEITED
}

enum VestingStatus {
  PENDING
  VESTED
  CANCELLED
}

enum TaxEventType {
  VESTING_TAX
  EXERCISE_TAX
}

enum TaxEventStatus {
  PENDING
  PAID
  CONFIRMED
}

enum AssetType {
  COMMON_SHARE
  PREFERRED_SHARE
  LP_SHARE
  VIRTUAL_SHARE
}

enum AccountStatus {
  ACTIVE      // 正常
  FROZEN      // 冻结
  CANCELLED   // 注销
}

enum AssetTxType {
  SETTLEMENT   // 交割入账 +
  REPURCHASE   // 回购 -
  DIVIDEND     // 分红 +
  REDEEM       // 兑现 -
  CANCEL       // 注销 -
}

enum ApplicationType {
  EXERCISE
  TRANSFER
  DIVIDEND
  REDEEM
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}
